msgstr "рывков на круг"

msgid "config"
msgstr "конфиг"

msgid "configuration"
msgstr "конфигурация мотора"

msgid "display this help and exit"
msgstr "выдать эту подсказку и сдохнуть"

msgid "fraction"
msgstr "дробь"

msgid ""
"is the pair of numbers separated by a '-' sign. In this pair, the first or "
"second or even both numbers can be omitted (one '-' remains) or one number "
"can be specified (there will be a range of one number)"
msgstr ""
"это пара чисел через знак '-', в ней первое или второе или даже оба числа "
"можно опустить (будет один '-') или указать одно (типа диапазон из одного "
"числа)"

msgid "magnet poles"
msgstr "магнитных полюсов ротора"

